{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "madoguchi/comparison-row",
	"title": "比較テーブルの行",
	"category": "madoguchi",
	"icon": "editor-justify",
	"description": "比較テーブルの1行。1列目の名称・評価・各列の値と、CTA列に置くブロックを持ちます。",
	"textdomain": "madoguchi-blocks",
	"editorScript": "madoguchi-blocks-editor",
	"style": "madoguchi-blocks-style",
	"render": "file:./render.php",
	"parent": [ "madoguchi/comparison-table" ],
	"usesContext": [ "madoguchi/comparisonColumns", "madoguchi/comparisonNameLabel" ],
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"name": {
			"type": "string",
			"default": ""
		},
		"rating": {
			"type": "number",
			"default": 0
		},
		"values": {
			"type": "array",
			"default": []
		},
		"nameColor": {
			"type": "string",
			"default": ""
		}
	}
}
