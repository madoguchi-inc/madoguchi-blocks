{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "madoguchi/comparison-table",
	"title": "買取業者比較テーブル",
	"category": "madoguchi",
	"icon": "editor-table",
	"description": "買取業者を一覧で比較できるテーブル。列を自由に増やせ、各行のCTA列にはCTAボタン等のブロックを入れられます。スマホでは横スクロール（店名列は固定）。",
	"textdomain": "madoguchi-blocks",
	"editorScript": "madoguchi-blocks-editor",
	"style": "madoguchi-blocks-style",
	"viewScript": "madoguchi-blocks-view",
	"render": "file:./render.php",
	"providesContext": {
		"madoguchi/comparisonColumns": "columns"
	},
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"caption": {
			"type": "string",
			"default": ""
		},
		"articleId": {
			"type": "string",
			"default": ""
		},
		"accentColor": {
			"type": "string",
			"default": ""
		},
		"fontSize": {
			"type": "number",
			"default": 14
		},
		"columns": {
			"type": "array",
			"default": [
				{ "label": "買取方法" },
				{ "label": "対応エリア" }
			]
		}
	}
}
